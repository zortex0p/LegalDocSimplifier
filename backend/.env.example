# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
PORT=5000

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
# Use SQLite for development (default)
# DATABASE_URL=sqlite:///legal_documents.db

# For PostgreSQL production
# DATABASE_URL=postgresql://user:password@localhost/legal_documents_db

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Model Configuration
LEGAL_BERT_MODEL=nlpaueb/legal-bert-base-uncased
LLM_MODEL=claude-3-5-sonnet-20241022
